{
  "version": 2,
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/(app.min.js|styles.css)",
      "headers": { "Cache-Control": "public, max-age=3600, stale-while-revalidate=86400" },
      "continue": true
    },
    {
      "src": "/(sitemap.xml|robots.txt)",
      "headers": { "Cache-Control": "public, max-age=3600, stale-while-revalidate=86400" },
      "continue": true
    },
    {
      "src": "/api/account/([^/]+)",
      "dest": "/api/account/[action]?action=$1"
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
